[sub_resource type="GDScript" id="GDScript_sh265"]
script/source = "extends CharacterBody3D
@export var MAX_STAMINA = 30.0
@export var SPRINT = 5.0
const SPEED = 7.0
const JUMP_VELOCITY = 4.5
const RELAX = 2.0
var relax_time = 0.0
var stamina = MAX_STAMINA
var mouse_sensitivity: float = 0.001
var autorun = false
var banana_count = 0
func _ready() -> void:
	Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
func _input(event: InputEvent) -> void:
	if event is InputEventMouseMotion:
		rotate_y(-event.relative.x * mouse_sensitivity)
		var pitch_delta = -event.relative.y * mouse_sensitivity
		$Camera3D.rotation.x = clamp(
			$Camera3D.rotation.x + pitch_delta,
			-PI/2, PI/2)
func _physics_process(delta: float) -> void:
	if not is_on_floor():
		velocity += get_gravity() * delta
	if Input.is_action_just_pressed(\"jump\") and is_on_floor():
		velocity.y = JUMP_VELOCITY
	if Input.is_action_just_pressed(\"auto_run\"):
		autorun = not autorun
	var input_dir := Input.get_vector(\"left\", \"right\", \"front\", \"back\")
	if autorun and input_dir.y == 0.0:
		input_dir.y = -1.0
	else:
		autorun = false
	var direction := (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	if direction:
		var player_speed = SPEED
		if relax_time <= 0:
			$CanvasLayer/stamina/stamina_line.color = Color('dbcf5a')
			if stamina > 0:
				if Input.is_action_pressed('sprint'):
					player_speed *= SPRINT
					stamina = max(0, stamina - delta * SPRINT)
				else:
					stamina = min(MAX_STAMINA, stamina + delta)
			else:
				relax_time = RELAX
				$CanvasLayer/stamina/stamina_line.color = Color('5b1420')
		else:
			stamina = min(MAX_STAMINA, stamina + delta)
			relax_time = max(0, relax_time - delta)
		velocity.x = direction.x * player_speed
		velocity.z = direction.z * player_speed
	else:
		stamina = min(MAX_STAMINA, stamina + delta * SPRINT)
		relax_time = max(0, relax_time - delta * SPRINT)
		velocity.x = move_toward(velocity.x, 0, SPEED)
		velocity.z = move_toward(velocity.z, 0, SPEED)
	move_and_slide()

func _process(_delta: float) -> void:
	$CanvasLayer/stamina/stamina_line.size.x = stamina * 100 / MAX_STAMINA * 2
	$CanvasLayer/Label.text = 'Banans: {0}'.format([banana_count], '{_}')
	if banana_count == 10:
		print('win')
		Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
		get_tree().paused = true
		
"

