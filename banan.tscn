[sub_resource type="GDScript" id="GDScript_j2txv"]
script/source = "extends Area3D

@onready var target = $'../..'.get_node('PLAYER')

func _ready() -> void:
	$\"banana/AnimationPlayer\".current_animation = \"Action\"
	$\"banana/AnimationPlayer\".speed_scale = 0.5
	$\"banana/AnimationPlayer\".play()

func _on_body_entered(body: Node3D) -> void:
	if body == target:
		body.banana_count += 1
		body.stamina += 5.0
		body.relax_time = 0.0
		queue_free()
"

